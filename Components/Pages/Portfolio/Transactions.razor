@page "/transactions"
@rendermode InteractiveServer
@using GestionPortefeuille.Models
@using GestionPortefeuille.Services
@inject IPortfolioService PortfolioService
@inject NavigationManager Navigation

<PageTitle>Transactions - Gestion Portefeuille</PageTitle>

<h2>📝 Historique des transactions</h2>

<button class="btn btn-success mb-3" @onclick='() => Navigation.NavigateTo("/add-transaction")'></button>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Date</th>
            <th>Actif</th>
            <th>Type</th>
            <th>Quantité</th>
            <th>Prix unitaire</th>
            <th>Total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var transaction in _transactions)
        {
            <tr>
                <td>@transaction.Date.ToShortDateString()</td>
                <td>@transaction.Asset?.Symbol</td>
                <td class="@(transaction.Type == "Achat" ? "text-success" : "text-danger")">
                    @transaction.Type
                </td>
                <td>@transaction.Quantity</td>
                <td>@transaction.PricePerUnit.ToString("C")</td>
                <td>@transaction.TotalAmount.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Transaction> _transactions = new();

    protected override async Task OnInitializedAsync()
    {
        _transactions = await PortfolioService.GetTransactionsAsync();
    }
}